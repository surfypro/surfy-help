{
  // This file is not used in compilation. It is here just for a nice editor experience.
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "resolveJsonModule": true,
    "jsx": "react-jsx", // or "react"
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "coverage",
    "docs-en",
    "docs-fr"
  ]
}